# Copy this file to .env and fill in the values.
# .env is git-ignored and must never be committed.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/taskdb

# JWT secret — generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# JWT settings (optional — these are the defaults)
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI (set when using AI features)
OPENAI_API_KEY=

# LangSmith tracing and project (optional; enable tracing when debugging pipelines)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
